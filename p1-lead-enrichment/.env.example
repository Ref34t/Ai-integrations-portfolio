# ─────────────────────────────────────────────
# P1: AI-Powered CRM Lead Enrichment System
# Copy this file to .env and fill in all values
# Never commit .env to git
# ─────────────────────────────────────────────

# HubSpot
HUBSPOT_CLIENT_ID=          # HubSpot OAuth2 client ID
HUBSPOT_CLIENT_SECRET=      # HubSpot OAuth2 client secret
HUBSPOT_REDIRECT_URI=       # OAuth2 redirect URI (e.g. https://your-domain.com/auth/callback)
HUBSPOT_WEBHOOK_SECRET=     # Used to verify incoming webhook signatures

# Clearbit
CLEARBIT_API_KEY=           # Clearbit enrichment API key

# Hunter.io
HUNTER_API_KEY=             # Hunter.io email validation API key

# Anthropic (Claude)
ANTHROPIC_API_KEY=          # Claude API key from console.anthropic.com

# Slack
SLACK_WEBHOOK_URL=          # Slack incoming webhook URL for sales notifications
SLACK_FALLBACK_EMAIL=       # Email to notify if Slack fails

# Database
DATABASE_URL=               # PostgreSQL connection string (e.g. postgresql://user:pass@localhost:5432/p1_leads)

# Redis
REDIS_URL=                  # Redis connection string (e.g. redis://localhost:6379)

# Internal API Security
JWT_SECRET=                 # Strong random string for signing internal JWTs (min 32 chars)
JWT_EXPIRY_MINUTES=60       # JWT token expiry in minutes

# App Settings
APP_ENV=local               # local | staging | production
HOT_LEAD_THRESHOLD=7        # Minimum score to classify a lead as hot (1-10)
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# GCP (production only)
GCP_PROJECT_ID=             # Google Cloud project ID
GCP_REGION=europe-west1     # GCP region for Cloud Run deployment

# PostgreSQL (local/docker only — in production use DATABASE_URL)
POSTGRES_USER=p1user
POSTGRES_PASSWORD=p1pass
POSTGRES_DB=p1_leads
